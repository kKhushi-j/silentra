rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /devices/{deviceId} {
      allow read, write: if true; // WARNING: Publicly accessible. Secure before production.
    }
    match /sensors/{sensorId} {
      allow read, write: if true; // WARNING: Publicly accessible. Secure before production.
    }
  }
}
